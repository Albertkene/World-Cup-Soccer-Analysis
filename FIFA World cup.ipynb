import pandas as pd
import matplotlib.pyplot as plt
from scipy.stats import shapiro
from scipy.stats import mannwhitneyu
df1 = pd.read_csv("men_results.csv")
df2 = pd.read_csv("women_results.csv")
df1["gender"] = "men"
df2["gender"] = "women"
df = pd.concat([df1, df2], ignore_index = True)
df.head()
df.info
df.value_counts("tournament")
df["date"] = pd.to_datetime(df["date"], errors = 'coerce')
df_wc = df[df["tournament"] == 'FIFA World Cup']
main_df = df_wc[df_wc["date"] >= "2002-01-01"]
main_df.info
main_df["total_goals"] = main_df["away_score"] + main_df["home_score"]
women_goals = main_df[main_df["gender"] == "women"]["total_goals"]
men_goals = main_df[main_df["gender"] == "men"]["total_goals"]
women_goals.count(), men_goals.count()
plt.hist(women_goals, bins=15, alpha=0.6, label='Women')
plt.hist(men_goals, bins=15, alpha=0.6, label='Men')
plt.xlabel('Total Goals per Match')
plt.ylabel('Frequency')
plt.title('Distribution of Goals in International Soccer Matches')
plt.legend()
plt.show()
shapiro(women_goals)
shapiro(men_goals)
u_stat, p_value = mannwhitneyu(
    women_goals,
    men_goals,
    alternative='greater'  # women > men
)

p_value
alpha = 0.10

if p_value < alpha:
    decision = "Reject the null hypothesis"
else:
    decision = "Fail to reject the null hypothesis"

decision
#Hence, we conclude that the mean number of goals in women's international soccer is greater than men's.
print(p_value)
